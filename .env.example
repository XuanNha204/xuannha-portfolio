# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/xuannha-dev

# ── NextAuth ──────────────────────────────────────────────
# Tạo secret: openssl rand -base64 32  (hoặc: npx auth secret)
AUTH_SECRET=your-random-secret-at-least-32-chars
AUTH_TRUST_HOST=true

# ── Site URL (dùng cho SEO, sitemap, RSS) ─────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Tài khoản quản trị (dùng bởi npm run seed) ────────────
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-strong-password
ADMIN_NAME=Your Name

# ── Chatbot AI (đa provider, tự failover) ─────────────────
# Route thử lần lượt các provider CÓ KEY; lỗi thì tự chuyển sang cái kế tiếp.
# Thứ tự ưu tiên (tuỳ chọn), vd: openai,gemini,deepseek,llama
CHAT_PROVIDER_ORDER=llama,openai,gemini,deepseek

# Llama qua NVIDIA (integrate.api.nvidia.com). LLAMA_MODEL nhận NHIỀU model
# cách nhau bằng dấu phẩy — chung 1 key: model đầu quá tải thì tự thử model kế.
LLAMA_API_KEY=
LLAMA_BASE_URL=https://integrate.api.nvidia.com/v1
LLAMA_MODEL=meta/llama-4-maverick-17b-128e-instruct,meta/llama-3.3-70b-instruct,meta/llama-3.1-8b-instruct

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (dùng endpoint OpenAI-compatible của Google)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
